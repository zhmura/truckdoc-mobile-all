<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="app.camera.tdoc.camera_library"
    android:installLocation="auto">

    <!-- don't update to 23 yet, need to update for permissions https://developer.android.com/training/permissions/requesting.html -->

    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true"
        android:xlargeScreens="true" />

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.microphone" />


    <application
        android:allowBackup="true"
        android:largeHeap="true"
        android:theme="@style/Theme.MaterialComponents.Light">
        <activity
            android:name=".CamActivity"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:label="@string/app_name"
            android:screenOrientation="landscape"></activity>
        <activity android:name=".GalleryActivity"></activity>

    </application>
</manifest>


pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '15'))
  }

  parameters {
    // Version parameters for client app
    string(name: 'CLIENT_VERSION', defaultValue: '', 
      description: 'Client app version (e.g. 1.2.3). Leave empty to use git tag.')
    
    // Version parameters for updater app
    string(name: 'UPDATER_VERSION', defaultValue: '', 
      description: 'Updater app version (e.g. 1.0.5). Leave empty to match client version.')
    
    // GitHub release parameters
    booleanParam(name: 'PUBLISH_GITHUB_RELEASE', defaultValue: false,
      description: 'Set to true to publish the release APKs to GitHub using the gh CLI.')
    string(name: 'RELEASE_TAG', defaultValue: '', 
      description: 'Git tag to create or update (e.g. v1.0.0). Leave empty to use CLIENT_VERSION.')
    string(name: 'RELEASE_TITLE', defaultValue: 'TruckDoc Android Release', 
      description: 'Title shown on the GitHub Release page.')
    text(name: 'RELEASE_NOTES', defaultValue: 'Automated release from Jenkins.', 
      description: 'Body/notes for the GitHub Release.')
  }

  environment {
    JAVA_HOME = "/Library/Java/JavaVirtualMachines/amazon-corretto-17.jdk/Contents/Home"
    ANDROID_SDK_ROOT = "/Users/sanda/Library/Android/sdk"
    ANDROID_HOME = "/Users/sanda/Library/Android/sdk"
    GRADLE_USER_HOME = "${WORKSPACE}/.gradle"
    PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    // Name of the credential that stores a GitHub Personal Access Token with repo permissions.
    GITHUB_TOKEN_CREDENTIAL_ID = 'gh-cli-token'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Extract Versions') {
      steps {
        script {
          // Helper function to calculate version code
          // Formula: (major * 1000000) + (minor * 10000) + patch
          // Supports up to 9999 patches per minor version
          def calculateVersionCode = { versionName ->
            def parts = versionName.split('\\.')
            def major = parts.length > 0 ? parts[0].toInteger() : 0
            def minor = parts.length > 1 ? parts[1].toInteger() : 0
            def patch = parts.length > 2 ? parts[2].toInteger() : 0
            return (major * 1000000) + (minor * 10000) + patch
          }
          
          // Determine client app version
          def clientVersion = params.CLIENT_VERSION
          if (!clientVersion) {
            // Try git tag
            def gitTag = sh(
              script: 'git describe --tags --exact-match 2>/dev/null || echo ""',
              returnStdout: true
            ).trim()
            clientVersion = gitTag ? gitTag.replaceFirst(/^v/, '') : "1.0.0"
          }
          
          env.CLIENT_VERSION_NAME = clientVersion
          env.CLIENT_VERSION_CODE = String.valueOf(calculateVersionCode(clientVersion))
          
          // Determine updater app version
          def updaterVersion = params.UPDATER_VERSION ?: clientVersion
          env.UPDATER_VERSION_NAME = updaterVersion
          env.UPDATER_VERSION_CODE = String.valueOf(calculateVersionCode(updaterVersion))
          
          // Determine release tag for GitHub
          def releaseTag = params.RELEASE_TAG ?: "v${clientVersion}"
          env.RELEASE_TAG_NAME = releaseTag
          
          echo "Client App Version: ${env.CLIENT_VERSION_NAME} (code: ${env.CLIENT_VERSION_CODE})"
          echo "Updater App Version: ${env.UPDATER_VERSION_NAME} (code: ${env.UPDATER_VERSION_CODE})"
          echo "Release Tag: ${env.RELEASE_TAG_NAME}"
        }
      }
    }

    stage('Environment Diagnostics') {
      steps {
        sh '''
          set -e
          echo "JAVA_HOME=$JAVA_HOME"
          echo "ANDROID_SDK_ROOT=$ANDROID_SDK_ROOT"
          echo "PATH=$PATH"
          echo "Client Version: $CLIENT_VERSION_NAME (code: $CLIENT_VERSION_CODE)"
          echo "Updater Version: $UPDATER_VERSION_NAME (code: $UPDATER_VERSION_CODE)"
          echo "Release Tag: $RELEASE_TAG_NAME"
          java -version
          if command -v sdkmanager >/dev/null 2>&1; then sdkmanager --version; fi
          ./gradlew --version
        '''
      }
    }

    stage('Prepare Gradle Dependencies') {
      steps {
        sh './gradlew --no-daemon --stacktrace help'
      }
    }

    stage('Assemble Release APKs') {
      steps {
        sh '''
          # Clean build directories
          rm -rf app-updater/build truckdoc-client-m2/application/build
          ./gradlew --no-daemon --stacktrace clean
          
          # Build client app with its version
          echo "Building client app v$CLIENT_VERSION_NAME (code: $CLIENT_VERSION_CODE)"
          ./gradlew --no-daemon --stacktrace \
            -PversionName=$CLIENT_VERSION_NAME \
            -PversionCode=$CLIENT_VERSION_CODE \
            :app:assembleRelease
          
          # Build updater app with its version
          echo "Building updater app v$UPDATER_VERSION_NAME (code: $UPDATER_VERSION_CODE)"
          ./gradlew --no-daemon --stacktrace \
            -PversionName=$UPDATER_VERSION_NAME \
            -PversionCode=$UPDATER_VERSION_CODE \
            :app-updater:assembleRelease
        '''
      }
    }

    stage('Verify APK Versions') {
      steps {
        script {
          // Verify APK versions match what we built
          def mainAppApk = sh(
            script: 'find truckdoc-client-m2/application/build/outputs/apk -name "*.apk" -type f | head -n 1',
            returnStdout: true
          ).trim()
          
          def updaterApk = sh(
            script: 'find app-updater/build/outputs/apk -name "*.apk" -type f | head -n 1',
            returnStdout: true
          ).trim()
          
          if (mainAppApk) {
            def actualVersion = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${mainAppApk}' | grep versionName | sed -E \"s/.*versionName='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            def actualCode = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${mainAppApk}' | grep versionCode | sed -E \"s/.*versionCode='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            echo "✅ Client APK verified: v${actualVersion} (code: ${actualCode})"
            
            if (actualVersion != env.CLIENT_VERSION_NAME) {
              error("Client APK version mismatch! Expected: ${env.CLIENT_VERSION_NAME}, Got: ${actualVersion}")
            }
          }
          
          if (updaterApk) {
            def actualVersion = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${updaterApk}' | grep versionName | sed -E \"s/.*versionName='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            def actualCode = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${updaterApk}' | grep versionCode | sed -E \"s/.*versionCode='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            echo "✅ Updater APK verified: v${actualVersion} (code: ${actualCode})"
            
            if (actualVersion != env.UPDATER_VERSION_NAME) {
              error("Updater APK version mismatch! Expected: ${env.UPDATER_VERSION_NAME}, Got: ${actualVersion}")
            }
          }
          
          // Set build description with both versions
          currentBuild.description = "Client: v${env.CLIENT_VERSION_NAME} | Updater: v${env.UPDATER_VERSION_NAME}"
        }
      }
    }

    stage('Archive Artifacts') {
      steps {
        archiveArtifacts artifacts: 'truckdoc-client-m2/application/build/outputs/apk/**/release/*.apk, app-updater/build/outputs/apk/**/release/*.apk', fingerprint: true
        stash name: 'release-apks', includes: 'truckdoc-client-m2/application/build/outputs/apk/**/release/*.apk, app-updater/build/outputs/apk/**/release/*.apk'
      }
    }

    stage('Publish GitHub Release') {
      when {
        allOf {
          expression { return params.PUBLISH_GITHUB_RELEASE }
          expression { return params.RELEASE_TAG?.trim() }
        }
      }
      steps {
        withCredentials([string(credentialsId: GITHUB_TOKEN_CREDENTIAL_ID, variable: 'GH_TOKEN')]) {
          sh '''
            set -e
            
            # Use full path to gh CLI
            GH_CLI="/opt/homebrew/bin/gh"
            if [ ! -x "$GH_CLI" ]; then
              GH_CLI="/usr/local/bin/gh"
            fi
            
            if [ ! -x "$GH_CLI" ]; then
              echo "GitHub CLI (gh) is required to publish releases" >&2
              echo "Tried: /opt/homebrew/bin/gh, /usr/local/bin/gh" >&2
              exit 1
            fi
            
            echo "Using GitHub CLI at: $GH_CLI"

            # Find APKs
            MAIN_APP_DIR="truckdoc-client-m2/application/build/outputs/apk/defaultClient/release"
            UPDATER_DIR="app-updater/build/outputs/apk/release"
            
            MAIN_APK=$(ls -t "$MAIN_APP_DIR"/*.apk | head -n 1)
            UPDATER_APK=$(ls -t "$UPDATER_DIR"/*.apk | head -n 1)
            
            if [ ! -f "$MAIN_APK" ]; then
              echo "Main app APK not found" >&2
              exit 1
            fi

            if [ ! -f "$UPDATER_APK" ]; then
              echo "Updater APK not found" >&2
              exit 1
            fi
            
            echo "Main APK: $MAIN_APK"
            echo "Updater APK: $UPDATER_APK"

            export GH_TOKEN
            
            # Authenticate with GitHub CLI
            echo "$GH_TOKEN" | $GH_CLI auth login --with-token || true
            $GH_CLI auth status

            # Recreate release to ensure the assets are up to date
            echo "Creating GitHub release: $RELEASE_TAG_NAME"
            echo "Client version: $CLIENT_VERSION_NAME"
            echo "Updater version: $UPDATER_VERSION_NAME"
            
            $GH_CLI release delete "$RELEASE_TAG_NAME" --yes 2>/dev/null || true
            $GH_CLI release create "$RELEASE_TAG_NAME" \
              "$MAIN_APK" \
              "$UPDATER_APK" \
              --title "$RELEASE_TITLE" \
              --notes "$RELEASE_NOTES
              
Client App: v$CLIENT_VERSION_NAME (versionCode: $CLIENT_VERSION_CODE)
Updater App: v$UPDATER_VERSION_NAME (versionCode: $UPDATER_VERSION_CODE)"
          '''
        }
      }
    }
  }

  post {
    success {
      script {
        echo '✅ Release build completed successfully!'
        echo "📱 Client App: v${env.CLIENT_VERSION_NAME} (code: ${env.CLIENT_VERSION_CODE})"
        echo "🔄 Updater App: v${env.UPDATER_VERSION_NAME} (code: ${env.UPDATER_VERSION_CODE})"
        if (env.RELEASE_TAG_NAME) {
          echo "🏷️  Release Tag: ${env.RELEASE_TAG_NAME}"
        }
        echo '📦 APKs are archived and ready for distribution.'
      }
    }
    cleanup {
      sh 'rm -rf $WORKSPACE/.gradle'
    }
  }
}

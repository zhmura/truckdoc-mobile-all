pipeline {
  agent any

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '15'))
  }

  parameters {
    booleanParam(name: 'PUBLISH_GITHUB_RELEASE', defaultValue: false,
      description: 'Set to true to publish the release APK to GitHub using the gh CLI.')
    string(name: 'RELEASE_TAG', defaultValue: '', description: 'Git tag to create or update (e.g. v1.0.0). Required when publishing.')
    string(name: 'RELEASE_TITLE', defaultValue: 'TruckDoc Android Release', description: 'Title shown on the GitHub Release page.')
    text(name: 'RELEASE_NOTES', defaultValue: 'Automated release from Jenkins.', description: 'Body/notes for the GitHub Release.')
  }

  environment {
    JAVA_HOME = "/Library/Java/JavaVirtualMachines/amazon-corretto-17.jdk/Contents/Home"
    ANDROID_SDK_ROOT = "/Users/sanda/Library/Android/sdk"
    ANDROID_HOME = "/Users/sanda/Library/Android/sdk"
    GRADLE_USER_HOME = "${WORKSPACE}/.gradle"
    PATH = "/opt/homebrew/bin:/usr/local/bin:${env.PATH}"
    // Name of the credential that stores a GitHub Personal Access Token with repo permissions.
    GITHUB_TOKEN_CREDENTIAL_ID = 'gh-cli-token'
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Environment Diagnostics') {
      steps {
        sh '''
          set -e
          echo "JAVA_HOME=$JAVA_HOME"
          echo "ANDROID_SDK_ROOT=$ANDROID_SDK_ROOT"
          echo "PATH=$PATH"
          java -version
          if command -v sdkmanager >/dev/null 2>&1; then sdkmanager --version; fi
          ./gradlew --version
        '''
      }
    }

    stage('Prepare Gradle Dependencies') {
      steps {
        sh './gradlew --no-daemon --stacktrace help'
      }
    }

    stage('Assemble Release APKs') {
      steps {
        sh '''
          # Clean build directories
          rm -rf app-updater/build truckdoc-client-m2/application/build
          ./gradlew --no-daemon --stacktrace clean
          ./gradlew --no-daemon --stacktrace :app:assembleRelease :app-updater:assembleRelease
        '''
      }
    }

    stage('Extract APK Versions') {
      steps {
        script {
          // Extract main app version
          def mainAppApk = sh(
            script: 'find truckdoc-client-m2/application/build/outputs/apk -name "*.apk" -type f | head -n 1',
            returnStdout: true
          ).trim()
          
          if (mainAppApk) {
            def mainAppVersionName = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${mainAppApk}' | grep versionName | sed -E \"s/.*versionName='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            def mainAppVersionCode = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${mainAppApk}' | grep versionCode | sed -E \"s/.*versionCode='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            env.MAIN_APP_VERSION_NAME = mainAppVersionName
            env.MAIN_APP_VERSION_CODE = mainAppVersionCode
            echo "Main App Version: ${mainAppVersionName} (${mainAppVersionCode})"
          }
          
          // Extract app-updater version
          def updaterApk = sh(
            script: 'find app-updater/build/outputs/apk -name "*.apk" -type f | head -n 1',
            returnStdout: true
          ).trim()
          
          if (updaterApk) {
            def updaterVersionName = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${updaterApk}' | grep versionName | sed -E \"s/.*versionName='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            def updaterVersionCode = sh(
              script: "\$ANDROID_HOME/build-tools/34.0.0/aapt dump badging '${updaterApk}' | grep versionCode | sed -E \"s/.*versionCode='([^']+)'.*/\\1/\"",
              returnStdout: true
            ).trim()
            
            env.UPDATER_VERSION_NAME = updaterVersionName
            env.UPDATER_VERSION_CODE = updaterVersionCode
            echo "App Updater Version: ${updaterVersionName} (${updaterVersionCode})"
          }
          
          // Set build description
          currentBuild.description = "Main: ${env.MAIN_APP_VERSION_NAME ?: 'N/A'} | Updater: ${env.UPDATER_VERSION_NAME ?: 'N/A'}"
        }
      }
    }

    stage('Archive Artifacts') {
      steps {
        archiveArtifacts artifacts: 'truckdoc-client-m2/application/build/outputs/apk/**/release/*.apk, app-updater/build/outputs/apk/**/release/*.apk', fingerprint: true
        stash name: 'release-apks', includes: 'truckdoc-client-m2/application/build/outputs/apk/**/release/*.apk, app-updater/build/outputs/apk/**/release/*.apk'
      }
    }

    stage('Publish GitHub Release') {
      when {
        allOf {
          expression { return params.PUBLISH_GITHUB_RELEASE }
          expression { return params.RELEASE_TAG?.trim() }
        }
      }
      steps {
        withCredentials([string(credentialsId: GITHUB_TOKEN_CREDENTIAL_ID, variable: 'GH_TOKEN')]) {
          sh '''
            set -e
            
            # Use full path to gh CLI
            GH_CLI="/opt/homebrew/bin/gh"
            if [ ! -x "$GH_CLI" ]; then
              GH_CLI="/usr/local/bin/gh"
            fi
            
            if [ ! -x "$GH_CLI" ]; then
              echo "GitHub CLI (gh) is required to publish releases" >&2
              echo "Tried: /opt/homebrew/bin/gh, /usr/local/bin/gh" >&2
              exit 1
            fi
            
            echo "Using GitHub CLI at: $GH_CLI"

            # Find APKs
            MAIN_APP_DIR="truckdoc-client-m2/application/build/outputs/apk/defaultClient/release"
            UPDATER_DIR="app-updater/build/outputs/apk/release"
            
            MAIN_APK=$(ls -t "$MAIN_APP_DIR"/*.apk | head -n 1)
            UPDATER_APK=$(ls -t "$UPDATER_DIR"/*.apk | head -n 1)
            
            if [ ! -f "$MAIN_APK" ]; then
              echo "Main app APK not found" >&2
              exit 1
            fi
            
            if [ ! -f "$UPDATER_APK" ]; then
              echo "Updater APK not found" >&2
              exit 1
            fi
            
            echo "Main APK: $MAIN_APK"
            echo "Updater APK: $UPDATER_APK"

            export GH_TOKEN
            
            # Authenticate with GitHub CLI
            echo "$GH_TOKEN" | $GH_CLI auth login --with-token || true
            $GH_CLI auth status

            # Recreate release to ensure the assets are up to date
            $GH_CLI release delete "$RELEASE_TAG" --yes 2>/dev/null || true
            $GH_CLI release create "$RELEASE_TAG" \
              "$MAIN_APK" \
              "$UPDATER_APK" \
              --title "$RELEASE_TITLE" \
              --notes "$RELEASE_NOTES"
          '''
        }
      }
    }
  }

  post {
    success {
      script {
        echo '✅ Release build completed successfully!'
        echo "📱 Main App: v${env.MAIN_APP_VERSION_NAME} (${env.MAIN_APP_VERSION_CODE})"
        echo "🔄 App Updater: v${env.UPDATER_VERSION_NAME} (${env.UPDATER_VERSION_CODE})"
        echo '📦 APKs are archived and ready for distribution.'
      }
    }
    cleanup {
      sh 'rm -rf $WORKSPACE/.gradle'
    }
  }
}

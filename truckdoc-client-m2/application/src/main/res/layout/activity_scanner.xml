<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:padding="4dip"
    android:weightSum="2"
    tools:context=".ui.ScannerActivity_">

    <Button
        android:id="@+id/btnCMRScan"
        style="@style/ApnButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:layout_weight="1"
        android:drawableLeft="@drawable/ic_menu_copy_holo_light"
        android:background="@drawable/landscape_button_selector"
        android:text="@string/btn_scan_cmr" />

    <Button
        android:id="@+id/btnScanOthers"
        style="@style/ApnButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="8dp"
        android:drawableLeft="@drawable/ic_menu_copy_holo_light"
        android:layout_weight="1"
        android:background="@drawable/scan_button_selector"
        android:text="@string/btn_scan_others" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.sanda.truckdoc.client">

    <uses-feature android:name="android.hardware.camera" />
    <uses-feature android:name="android.hardware.camera.autofocus" />

    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.READ_PRIVILEGED_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.ACTION_MANAGE_ALL_FILES_ACCESS_PERMISSION" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        android:minSdkVersion="30" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.DISABLE_KEYGUARD" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.MANAGE_ALL_FILES_ACCESS_PERMISSION" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <uses-feature android:name="android.hardware.camera.flash" />

    <uses-permission android:name="android.hardware.camera.autofocus" />
    <uses-permission
        android:name="android.permission.FLASHLIGHT"
        android:permissionGroup="android.permission-group.HARDWARE_CONTROLS"
        android:protectionLevel="normal" />

    <application
        android:name=".TruckDocApp"
        android:icon="@drawable/icon"
        android:label="@string/app_name"
        android:requestLegacyExternalStorage="true"
        android:usesCleartextTraffic="true"
        tools:ignore="HardcodedDebugMode"
        tools:replace="android:icon"
        tools:targetApi="m">
        <activity
            android:name=".ui.SplashActivity_"
            android:icon="@drawable/icon"
            android:theme="@style/Base.Theme.AppCompat"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.RegisterActivity_"
            android:theme="@style/Base.Theme.AppCompat" />
        <activity
            android:name=".ui.UnauthorizedActivity_"
            android:theme="@style/Base.Theme.AppCompat" />
        <activity
            android:name=".ui.DashboardActivity_"
            android:theme="@style/Base.Theme.AppCompat" />
        <activity
            android:name=".ui.TruckdocPreferenceActivity_"
            android:label="@string/preferences_title"
            android:theme="@style/Theme.AppCompat" />
        <activity
            android:name=".ui.DialogActivity_"
            android:launchMode="singleTop"
            android:noHistory="true"
            android:showOnLockScreen="true"
            android:theme="@style/Theme.AppCompat.Dialog" />
        <activity
            android:name=".ui.message.InboxActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar" />
        <activity
            android:name=".ui.dgcam.NoCamera"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />
        <activity
            android:name=".ui.dgcam.NoSDCard"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />
        <activity
            android:name=".ui.ScannerActivity_"
            android:label="@string/activity_scanner_title"
            android:theme="@style/Theme.AppCompat" />

        <service android:name=".service.MessageCheckService" android:exported="true" />
        <service android:name=".to.service.NewMntService_" />

        <receiver android:name=".receivers.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
        <receiver android:name=".receivers.GetNewMessagesAlarmManager" />
        <receiver android:name=".receivers.IncomeMessagesAlarmManager" />
        <receiver
            android:name=".receivers.StartMyServiceAtBootReceiver"
            android:enabled="true"
            android:exported="true"
            android:label="StartMyServiceAtBootReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <service
            android:name=".service.intent.BootCompletedJobIntentService"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!--        <receiver android:name=".ui.floating.ApnWaiterReceiver">
                    <intent-filter>
                        <action android:name="com.sanda.truckdoc.client.ui.floating.ApnWaiterReceiver" />
                    </intent-filter>
                </receiver>-->

        <activity
            android:name=".wizard.wizardpager.ui.CameraActivity_"
            android:label="@string/title_activity_camera_wizard"
            android:screenOrientation="landscape" />
        <activity
            android:name=".wizard.wizardpager.WizardActivity"
            android:theme="@style/Theme.AppCompat.NoActionBar" />


        <activity
            android:name=".to.TOTreeActivity"
            android:label="TO"
            android:screenOrientation="portrait"
            android:configChanges="screenSize|orientation"
            android:theme="@style/MyMaterialTheme.Base" />

        <activity
            android:parentActivityName=".to.TOTreeActivity"
            android:name=".to.PerformMntActivity"
            android:label="TO"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <activity
            android:name=".to.EnterTruckDataActivity"
            android:screenOrientation="portrait"
            android:label="TO"
            android:theme="@style/Theme.AppCompat.Light" />
        <activity
            android:name=".to.UntrackedToItemsActivity"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light" />

        <service android:name=".ui.floating.HelpWindow" />
        <service android:name=".ui.floating.ApnHelpWindow" />

        <service
            android:name=".service.NewMessageService_"
            android:exported="false" />
        <!--
                <service
                    android:name=".service.intent.ConnectivityJob"
                    android:exported="true"
                    android:permission="android.permission.BIND_JOB_SERVICE" />
        -->

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.sanda.truckdoc.client.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/filepaths" />
        </provider>
    </application>

</manifest>

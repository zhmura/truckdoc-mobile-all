<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- The update server (TCUS) is served over plain HTTP. Allow cleartext only for it. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">tcus.truckdoc.ru</domain>
    </domain-config>
</network-security-config>
